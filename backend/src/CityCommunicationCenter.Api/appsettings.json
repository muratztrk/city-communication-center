{
  "ConnectionStrings": {
    "CityCommunicationCenter": ""
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Authentication": {
    "EnableLocalUsers": true,
    "InitialPassword": "",
    "Issuer": "https://city-communication-center.local",
    "Audience": "city-communication-center-api",
    "SigningKey": "",
    "SessionCookie": {
      "Name": "__Host-ccc-session",
      "SameSite": "Lax",
      "SecurePolicy": "Always",
      "ExpireMinutes": 480
    },
    "MobileOidc": {
      "ClientId": "ccc-mobile",
      "RedirectUri": "ccc.mobile:/oauth2redirect"
    },
    "Ldap": {
      "Enabled": false,
      "Host": "",
      "Port": 389,
      "UseSsl": false,
      "IgnoreCertificateErrors": false,
      "Domain": "",
      "SearchBase": "",
      "BindDn": "",
      "BindPassword": "",
      "UserAttribute": "mail"
    }
  },
  "DataProtection": {
    "KeysDirectory": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:13000",
      "http://localhost:5173"
    ]
  },
  "RateLimiting": {
    "PermitLimit": 120,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "TenantResolution": {
    "HeaderName": "X-Tenant-Id"
  },

  "ForwardedHeaders": {
    "AllowUntrustedForwardedHeaders": false,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "SocialWebhooks": {
    "SharedSecret": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.AspNetCore.Hosting": "Warning",
        "Microsoft.AspNetCore.Mvc": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "Microsoft.EntityFrameworkCore": "Error",
        "Microsoft.EntityFrameworkCore.Database.Command": "Error",
        "Npgsql": "Error",
        "OpenIddict": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
