CCC_DB_HOST=postgres
CCC_DB_PORT=5432
# Host machine port for local access to Postgres. Does not affect container-to-container traffic.
CCC_DB_HOST_PORT=5432
CCC_DB_NAME=city_communication_center
CCC_DB_USER=ccc
CCC_DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
CCC_DB_VOLUME_NAME=city-communication-center-postgres18-data

# If the database volume already exists, changing CCC_DB_PASSWORD here does not reset the existing DB user password.
# In that case either keep the old password or point CCC_DB_VOLUME_NAME to a new volume.

CCC_API_CONTAINER_PORT=80
# Host machine port for direct API access from your browser or local tools.
CCC_API_HOST_PORT=15000
# Leave empty when frontend and API are served from the same domain.
# Example for separate API host: https://cccdemo.theworkpc.com
CCC_API_PUBLIC_ORIGIN=
# Public frontend origin for CORS when frontend is served from a different origin than the API.
CCC_FRONTEND_PUBLIC_ORIGIN=http://localhost:13000
CCC_AUTH_ISSUER=https://city-communication-center.local
CCC_AUTH_AUDIENCE=city-communication-center-api
CCC_FRONTEND_HOST_PORT=13000
# Development-only seeded local-user password. Override this through environment variables in shared/prod deployments.
CCC_INITIAL_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
# IMPORTANT: Generate a cryptographically random key (at least 32 characters). Example: openssl rand -base64 48
CCC_SIGNING_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48
CCC_DP_KEYS_VOLUME_NAME=city-communication-center-dataprotection-keys
