FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY ["src/CityCommunicationCenter.Api/CityCommunicationCenter.Api.csproj", "src/CityCommunicationCenter.Api/"]
COPY ["src/CityCommunicationCenter.Application/CityCommunicationCenter.Application.csproj", "src/CityCommunicationCenter.Application/"]
COPY ["src/CityCommunicationCenter.Domain/CityCommunicationCenter.Domain.csproj", "src/CityCommunicationCenter.Domain/"]
COPY ["src/CityCommunicationCenter.Infrastructure/CityCommunicationCenter.Infrastructure.csproj", "src/CityCommunicationCenter.Infrastructure/"]
COPY ["src/CityCommunicationCenter.Shared/CityCommunicationCenter.Shared.csproj", "src/CityCommunicationCenter.Shared/"]

RUN dotnet restore "src/CityCommunicationCenter.Api/CityCommunicationCenter.Api.csproj"

COPY . .
RUN dotnet publish "src/CityCommunicationCenter.Api/CityCommunicationCenter.Api.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app

ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "CityCommunicationCenter.Api.dll"]
