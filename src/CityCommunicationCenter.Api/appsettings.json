{
  "ConnectionStrings": {
    "CityCommunicationCenter": "Server=(localdb)\\MSSQLLocalDB;Database=CityCommunicationCenter;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "CCC-Dev-Secret-Key-2024-Very-Long-For-Security!",
    "Issuer": "CityCommunicationCenter",
    "Audience": "CityCommunicationCenter"
  },
  "TenantResolution": {
    "HeaderName": "X-Tenant-Id"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ccc-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
